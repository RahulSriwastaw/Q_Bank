{
  "tech_stack": [
    "TypeScript",
    "React",
    "Vite",
    "Google GenAI SDK"
  ],
  "features": [
    {
      "name": "generateQuestions",
      "description": "Generates educational questions using Google Gemini AI based on provided parameters and input context (text, image, pdf, url).",
      "files": [
        "services/geminiService.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Question Generation API",
          "version": "1.0.0"
        },
        "paths": {
          "/generateQuestions": {
            "post": {
              "summary": "Generate questions",
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "subject": { "type": "string" },
                        "topic": { "type": "string" },
                        "difficulty": { "type": "string" },
                        "count": { "type": "integer" },
                        "inputMode": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}